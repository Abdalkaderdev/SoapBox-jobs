# =============================================================================
# SoapBox Jobs - Kubernetes Secrets (Example)
# =============================================================================
# Copy this file to secrets.yaml and fill in your values.
# DO NOT commit secrets.yaml to version control!
#
# To create the secret:
# kubectl create secret generic soapbox-jobs-secrets \
#   --from-literal=database-url='postgresql://...' \
#   --from-literal=sso-jwt-secret='...' \
#   -n soapbox
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: soapbox-jobs-secrets
  namespace: soapbox
type: Opaque
stringData:
  # Neon PostgreSQL database URL
  database-url: "postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/soapbox_jobs?sslmode=require"
  # JWT secret for SSO token validation (must match SoapBox Super App)
  sso-jwt-secret: "your-jwt-secret-here"
